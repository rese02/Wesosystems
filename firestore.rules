rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hotels collection
    // Agency can read/write individual hotel documents and list the collection.
    // Hoteliers can only read their own specific hotel document.
    match /hotels/{hotelId} {
      // Allow agency to list all hotels. THIS IS THE FIX.
      allow list: if request.auth.token.role == 'agency';

      // Allow agency to read any single hotel, and hoteliers to read their own.
      allow get: if request.auth.token.role == 'agency' || (request.auth.token.role == 'hotelier' && request.auth.token.hotelId == hotelId);
      
      // Allow only agency to create, update, or delete hotels.
      allow write: if request.auth.token.role == 'agency';

      // Bookings sub-collection for a hotel
      match /bookings/{bookingId} {
        // Agency can read/write bookings for any hotel.
        // Hoteliers can read/write bookings for their own hotel.
        allow read, write: if request.auth.token.role == 'agency' 
                           || (request.auth.token.role == 'hotelier' && request.auth.token.hotelId == hotelId);
      }
    }

    // Booking Links collection
    // Any user (including unauthenticated guests) can read a link, as it's needed for the guest page.
    // Agency and hoteliers can create links.
    // Guests can update their own link (to mark it as 'used').
    match /bookingLinks/{linkId} {
      allow get: if true;
      allow create: if request.auth.token.role == 'agency' || request.auth.token.role == 'hotelier';
      allow update: if request.auth == null || request.auth.token.role == 'agency' || (request.auth.token.role == 'hotelier' && request.auth.token.hotelId == resource.data.hotelId);
      allow list, delete: if request.auth.token.role == 'agency';
    }
  }
}
